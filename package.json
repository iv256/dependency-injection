{
  "name": "dependency-injection",
  "type": "module",
  "version": "0.1.0",
  "main": "src/index.js",
  "scripts": {
    "lint": "eslint . -c .dev-tools/eslint.config.js",
    "lint:file": "eslint -c .dev-tools/eslint.config.js",
    "lint:fix": "eslint . -c .dev-tools/eslint.config.js --fix",
    "format": "prettier --write . --config .dev-tools/prettier.config.js",
    "doc": "jsdoc -c .dev-tools/jsdoc.json",

    "example:simple-dependency": "node examples/simple.dependency.js",
    "example:dependency-list": "node examples/dependency.list.js",
    "example:dependency-chain": "node examples/dependency.chain.js",
    "example:functional-dependency": "node examples/functional.dependency.js",
    "example:class-injection": "node examples/class.injection.js",

    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "dependency-injection",
    "inversion-of-control",
    "lazy-evaluation"
  ],
  "author": "",
  "license": "MIT",
  "description": "A dependency injection container with lazy, promise-based resolution",
  "devDependencies": {
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^52.0.1",
    "eslint-plugin-prettier": "^5.5.3",
    "jsdoc": "^4.0.4",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "vitest": "^4.1.5"
  }
}
